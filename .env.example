# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=flowpath
POSTGRES_USER=flowpath
POSTGRES_PASSWORD=flowpath_dev_password

# ── Django ────────────────────────────────────────────────────────────────────
# Generate a real one with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=dev-secret-key-change-in-production-absolutely
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# ── Anthropic (for AI workflow brief generation — Phase 2) ───────────────────
ANTHROPIC_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost/api
