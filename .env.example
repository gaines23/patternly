# ── LOCAL DEVELOPMENT ─────────────────────────────────────────────────────────
# Copy this file to .env for local dev:
#   cp .env.example .env

# Database (used by Docker Compose local db service)
POSTGRES_DB=flowpath
POSTGRES_USER=flowpath
POSTGRES_PASSWORD=flowpath_dev_password

# Django
# Generate a real one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost

# Anthropic (for AI workflow brief generation)
ANTHROPIC_API_KEY=

# Frontend
VITE_API_URL=http://localhost/api


# ── PRODUCTION ────────────────────────────────────────────────────────────────
# Copy this section to .env.prod (never commit .env.prod):
#   cp .env.example .env.prod
# Then fill in real values and run:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

# DATABASE_URL is provided directly by Railway/Render — paste it here for
# self-hosted prod deploys. Format:
#   postgres://USER:PASSWORD@HOST:PORT/DBNAME
# DATABASE_URL=

# Django — use a strong random secret key, never reuse the dev key
# SECRET_KEY=

# DEBUG must be False in production
# DEBUG=False

# Comma-separated list of your domain(s) and Railway/Render public URL
# ALLOWED_HOSTS=yourdomain.com,yourapp.up.railway.app

# CORS — set to your actual frontend origin(s)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Anthropic
# ANTHROPIC_API_KEY=

# Gunicorn worker count (default: 2, rule of thumb: 2 * CPU cores + 1)
# GUNICORN_WORKERS=2

# Email (optional — for invite emails)
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
